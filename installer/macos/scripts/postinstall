#!/bin/bash
# OpenAVC .pkg postinstall — runs as root after OpenAVC.app is in /Applications.
#
# Creates the data + log dirs, seeds the default project, installs the
# LaunchDaemon, and starts the server. This is the step that makes the .pkg a
# one-double-click install for a background service: the user never touches a
# plist or a sudo command.

set -u

APP="/Applications/OpenAVC.app"
DATA_DIR="/Library/Application Support/OpenAVC"
LOG_DIR="/Library/Logs/OpenAVC"
DAEMON_PLIST="/Library/LaunchDaemons/com.openavc.server.plist"
AGENT_PLIST="/Library/LaunchAgents/com.openavc.menubar.plist"
SEED="$APP/Contents/Resources/server/_internal/projects/default/project.avc"
DEST="$DATA_DIR/projects/default"

mkdir -p "$DATA_DIR" "$LOG_DIR"

# Seed the default project only if the user doesn't already have one (an
# upgrade or reinstall must never clobber a live project).
if [ ! -f "$DEST/project.avc" ] && [ -f "$SEED" ]; then
    mkdir -p "$DEST"
    cp "$SEED" "$DEST/project.avc"
fi

# Install the LaunchDaemon and (re)load it.
cp "$APP/Contents/Resources/com.openavc.server.plist" "$DAEMON_PLIST"
chown root:wheel "$DAEMON_PLIST"
chmod 644 "$DAEMON_PLIST"
launchctl bootout system "$DAEMON_PLIST" 2>/dev/null || true
launchctl bootstrap system "$DAEMON_PLIST"
launchctl enable system/com.openavc.server 2>/dev/null || true

# Install the menu-bar LaunchAgent and load it into the logged-in user's GUI
# session (a menu-bar app can't run as a daemon — it needs an Aqua session).
cp "$APP/Contents/Resources/com.openavc.menubar.plist" "$AGENT_PLIST"
chown root:wheel "$AGENT_PLIST"
chmod 644 "$AGENT_PLIST"

CONSOLE_UID="$(stat -f %u /dev/console 2>/dev/null)"
if [ -n "${CONSOLE_UID:-}" ] && [ "$CONSOLE_UID" != "0" ]; then
    launchctl bootout "gui/$CONSOLE_UID/com.openavc.menubar" 2>/dev/null || true
    launchctl bootstrap "gui/$CONSOLE_UID" "$AGENT_PLIST" 2>/dev/null || true
    # The browser is NOT opened here. The menu-bar app opens the Programmer on
    # its first launch, waiting for the server first. It runs as the user, so it
    # honors the default browser; opening from this root context would force
    # Safari regardless of the user's choice.
fi

exit 0
