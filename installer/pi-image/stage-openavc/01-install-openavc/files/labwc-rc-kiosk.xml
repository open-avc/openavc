<?xml version="1.0"?>
<!--
  labwc configuration for the OpenAVC user session.

  - Disables touch mouse emulation so native touch scrolling works
    (RPi OS defaults to mouseEmulation=yes which breaks swipe scroll)
  - Removes window decorations from Chromium (clean fullscreen)
-->
<labwc_config>
  <touch deviceName="" mouseEmulation="no"/>
  <windowRules>
    <windowRule identifier="chromium">
      <serverDecoration>no</serverDecoration>
      <skipTaskbar>yes</skipTaskbar>
    </windowRule>
  </windowRules>
</labwc_config>
