{
    "name": "Luxury",
    "id": "luxury",
    "version": "1.0.0",
    "author": "OpenAVC",
    "description": "Near-black with gold accents and serif-inspired typography — crafted for high-end residential.",
    "preview_colors": ["#0d0d0d", "#1a1a1a", "#D4AF37", "#e8e0d0"],
    "variables": {
        "panel_bg": "#0d0d0d",
        "panel_text": "#e8e0d0",
        "accent": "#D4AF37",
        "accent_hover": "#c9a230",
        "button_bg": "#1a1a1a",
        "button_text": "#e8e0d0",
        "button_active_bg": "#D4AF37",
        "button_active_text": "#0d0d0d",
        "button_border": "#3a3428",
        "danger": "#c0392b",
        "success": "#7dcea0",
        "warning": "#d4ac0d",
        "surface": "#141414",
        "surface_border": "#2a2620",
        "grid_gap": 8,
        "border_radius": 8,
        "font_family": "Georgia, 'Times New Roman', serif"
    },
    "element_defaults": {
        "button": {
            "bg_color": "#1a1a1a",
            "text_color": "#e8e0d0",
            "border_width": 1,
            "border_color": "#3a3428",
            "border_radius": 8,
            "box_shadow": "0 2px 8px rgba(212,175,55,0.08)"
        },
        "label": {
            "bg_color": "transparent",
            "text_color": "#e8e0d0",
            "border_width": 0,
            "border_color": "transparent",
            "border_radius": 0,
            "box_shadow": "none"
        },
        "slider": {
            "bg_color": "#141414",
            "border_width": 1,
            "border_color": "#2a2620",
            "border_radius": 8,
            "box_shadow": "inset 0 1px 3px rgba(0,0,0,0.4)"
        },
        "page_nav": {
            "bg_color": "#141414",
            "text_color": "#e8e0d0",
            "border_width": 1,
            "border_color": "#2a2620",
            "border_radius": 8,
            "box_shadow": "0 1px 4px rgba(212,175,55,0.06)"
        },
        "select": {
            "bg_color": "#141414",
            "text_color": "#e8e0d0",
            "border_width": 1,
            "border_color": "#2a2620",
            "border_radius": 8
        },
        "text_input": {
            "bg_color": "#141414",
            "text_color": "#e8e0d0",
            "border_width": 1,
            "border_color": "#2a2620",
            "border_radius": 8
        },
        "status_led": {
            "bg_color": "transparent"
        },
        "image": {
            "bg_color": "transparent"
        },
        "spacer": {
            "bg_color": "transparent"
        },
        "camera_preset": {
            "bg_color": "#1a1a1a",
            "text_color": "#e8e0d0",
            "border_width": 1,
            "border_color": "#3a3428",
            "border_radius": 8,
            "box_shadow": "0 2px 8px rgba(212,175,55,0.08)"
        },
        "gauge": {
            "bg_color": "transparent",
            "text_color": "#e8e0d0",
            "gauge_color": "#D4AF37",
            "gauge_bg_color": "#2a2620"
        },
        "level_meter": {
            "bg_color": "transparent"
        },
        "fader": {
            "bg_color": "transparent",
            "text_color": "#e8e0d0"
        },
        "group": {
            "bg_color": "rgba(212,175,55,0.03)",
            "text_color": "#8a7d65",
            "border_width": 1,
            "border_color": "#2a2620",
            "border_radius": 12
        },
        "clock": {
            "bg_color": "transparent",
            "text_color": "#e8e0d0"
        },
        "keypad": {
            "bg_color": "#141414",
            "text_color": "#e8e0d0",
            "border_width": 1,
            "border_color": "#2a2620",
            "border_radius": 8
        },
        "list": {
            "bg_color": "#0d0d0d",
            "text_color": "#e8e0d0",
            "border_width": 1,
            "border_color": "#2a2620",
            "border_radius": 8,
            "item_bg": "#141414",
            "item_active_bg": "#D4AF37"
        },
        "matrix": {
            "bg_color": "#0d0d0d",
            "text_color": "#e8e0d0",
            "border_width": 1,
            "border_color": "#2a2620",
            "border_radius": 8,
            "crosspoint_active_color": "#D4AF37",
            "crosspoint_inactive_color": "#2a2620"
        }
    },
    "page_defaults": {
        "background_color": "var(panel_bg)",
        "background_image": null,
        "background_gradient": null
    }
}
